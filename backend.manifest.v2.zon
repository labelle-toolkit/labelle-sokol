.{
    // ‚îÄ‚îÄ sokol backend manifest, SCHEMA v2 (build-graph manifest, epic
    // labelle-assembler#453 / manifest-v2 #461) ‚Äî the SHIPPED reference manifest
    // for the sokol backend. sokol is the reference provider, so this file is the
    // worked example other backends translate from (design
    // docs/design/manifest-v2-build-graph.md ¬ß3).
    //
    // This ships ALONGSIDE the retained v1 `backend.manifest.zon`: the v1 file has
    // NO `manifest_version` field and stays on the enum/splice path (byte-unchanged
    // desktop splice), while THIS file (`manifest_version = 2`) drives the v2
    // build-graph codegen. Keeping them as two files means the v2 route does not
    // disturb the v1-fixture tests other assembler code depends on. Do NOT bump the
    // v1 file to v2.
    //
    // The assembler's `generate` auto-detects this file and stages `.build_hook`
    // (below) next to the generated build.zig. Phase A wires only the DESKTOP entry
    // (`.callback` loop, `.native` target, empty hook residual); the android/ios/wasm
    // entries are authored here (faithful to ¬ß3) so the manifest is complete, and are
    // exercised through the assembler's golden-cell + hook gates as the shared
    // packager + hook phases land.
    .manifest_version = 2,
    .dir_name = "sokol",
    .dep_name = "labelle_sokol",
    .id = "labelle.sokol",

    // Carried forward from the v1 manifest UNCHANGED (same list sokol ships today,
    // backend.manifest.zon) ‚Äî v2 must not drop capability negotiation (design ¬ß3
    // review-correction #8).
    .capabilities = .{
        .screenshots,
        .compressed_textures,
        .fonts,
        .gamepad_polling,
        .raw_gui_adapter,
        .surface_loss,
        .wasm,
        .android,
        .ios,
        .audio_ogg,
    },

    // Curated material effects this backend implements (labelle-gfx#305) ‚Äî the
    // `.capabilities` mirror of `core.materialCapabilities(sokolImpl)` / the
    // runtime `materialSupported`. sokol implements the FULL curated set ‚Äî
    // `flash`, `palette_swap`, `dissolve`, `outline` (src/gfx/material.zig).
    // Inert until the resolve-side mirror lands (`ignore_unknown_fields`).
    // Mirrors labelle-bgfx v0.12.0's manifest field.
    .material_effects = .{ .flash, .palette_swap, .dissolve, .outline },

    // Curated full-screen post-fx passes this backend implements (labelle-gfx#305
    // Phase 3) ‚Äî the `.capabilities` mirror of `core.postFxCapabilities(sokolImpl)`
    // / the runtime `postPassSupported`. sokol implements ALL four built-ins
    // (src/gfx/render_target.zig + post_fx_shaders.zig); backends with no shader
    // dialect report false at runtime and the gfx `PostFxDriver` skips the pass.
    .post_fx_passes = .{ .bloom, .vignette, .color_grade, .crt },

    // root_alias defaults to `backend_<name>`, so the generated root imports
    // these as `backend_gfx`/`backend_input`/‚Ä¶ exactly as the enum path does.
    // Sources match the real repo layout (src/gfx.zig, src/input.zig,
    // src/audio.zig, src/window.zig).
    .modules = .{
        .{ .name = "gfx", .source = "src/gfx.zig" },
        .{ .name = "input", .source = "src/input.zig" },
        .{ .name = "audio", .source = "src/audio.zig" },
        .{ .name = "window", .source = "src/window.zig" },
    },

    // BASE dep_options: ONLY options common to EVERY platform (design ¬ß3 merge
    // contract). `with_imgui` is the only sokol flag all four platforms pass;
    // `gamepad_*` is desktop-only and `dont_link_system_libs` is mobile-only, so
    // both are per-platform appends below, never base entries. Mirrors the v1
    // backend_dep fragment's `b.dependency("labelle_sokol", .{ ‚Ä¶ })` option set.
    .dep_options = .{
        .{ .name = "with_imgui", .value = .gui_is_imgui },
    },

    .system_libs = .{
        // sokol links these NDK libs manually on Android (the enum path's
        // android link block). desktop/ios link via frameworks, not system libs.
        .android = .{ "android", "log", "GLESv3", "EGL" },
    },
    .frameworks = .{
        // IOSurface/CoreFoundation on Darwin desktop ‚Äî replaces the v1
        // build_fragments/link.txt macos/ios switch (the engine's IOSurface
        // preview producer references these via `@extern "c"`).
        .desktop = .{ .macos = .{ "IOSurface", "CoreFoundation" } },
        // Full iOS framework set, emitted declaratively by the assembler (replaces
        // the enum path's header_ios framework switch). Exercised in the iOS PR.
        .ios = .{ "Foundation", "UIKit", "Metal", "MetalKit", "AudioToolbox", "AVFoundation", "QuartzCore", "GameController" },
    },

    .platforms = .{
        .desktop = .{
            .entry = "templates/desktop.txt",
            .loop_style = .callback,
            // #461: the sokol callback SHAPE as manifest data (was the
            // `cfg.backend == .sokol` enum branch in the assembler). The
            // privileged `sokol_readback` is reserved to this manifest's
            // `labelle.*` id (assembler-side `assertLifecyclePrivilege`).
            .lifecycle = .{ .runner_module_var = true, .cleanup_callback = true, .allocator_holes = true, .gui_events = true, .imgui_dispatch = true, .preview = .sokol_readback },
            .target = .native,
            .artifacts = .{ .{ .name = "sokol_clib" } },
            // gamepad_* is desktop-only ‚Äî APPENDED to the base `with_imgui`, so
            // desktop's literal forwards all three flags (the v1 fragment's
            // with_imgui/gamepad_enabled/gamepad_hidapi param set).
            .dep_options = .{
                .{ .name = "gamepad_enabled", .value = .gamepad_enabled },
                .{ .name = "gamepad_hidapi", .value = .gamepad_hidapi },
            },
            .package = .binary,
        },
        .ios = .{
            .entry = "templates/mobile.txt",
            .loop_style = .callback,
            .lifecycle = .{ .runner_module_var = true, .cleanup_callback = true, .allocator_holes = true, .gui_events = true, .imgui_dispatch = true, .preview = .sokol_readback },
            .target = .resolved,
            .link_libc = true,
            .artifacts = .{ .{ .name = "sokol_clib" } },
            .dep_options = .{ .{ .name = "dont_link_system_libs", .value = .true_literal } },
            .package = .binary,
        },
        .android = .{
            .entry = "templates/mobile.txt",
            .loop_style = .callback,
            .lifecycle = .{ .runner_module_var = true, .cleanup_callback = true, .allocator_holes = true, .gui_events = true, .imgui_dispatch = true, .preview = .sokol_readback },
            .target = .resolved,
            .pic = true,
            .link_libc = true,
            .artifacts = .{ .{ .name = "sokol_clib", .pic = true } },
            .dep_options = .{ .{ .name = "dont_link_system_libs", .value = .true_literal } },
            .package = .{ .apk = .{ .manifest = "AndroidManifest.xml.tmpl" } },
        },
        .wasm = .{
            // sokol shares ONE entry template across desktop and wasm (both drive
            // sokol_app via `pub fn main()` ‚Üí `window.run`); the enum path proves
            // this (root.zig: "sokol uses a single template for desktop and wasm"),
            // so wasm reuses templates/desktop.txt rather than a separate wasm.txt.
            .entry = "templates/desktop.txt",
            .loop_style = .callback,
            .lifecycle = .{ .runner_module_var = true, .cleanup_callback = true, .allocator_holes = true, .gui_events = true, .imgui_dispatch = true, .preview = .sokol_readback },
            .target = .{ .triple = "wasm32-emscripten" },
            .artifacts = .{ .{ .name = "sokol_clib" } },
            .dep_options = .{},
            .root_build_deps = .{ .{ .name = "emsdk", .resolution = .builtin } },
            .package = .{ .web = .{ .shell = null } },
        },
    },

    // Dedicated hook file (NOT sokol's own build.zig, which re-exports
    // `@import("sokol")` at top level ‚Äî a name absent from the generated root
    // package). Desktop has an EMPTY post_wire and uses the built-in target
    // resolver, so the desktop path never invokes the hook; it exists for the
    // android/ios/wasm residual.
    .build_hook = "backend.hook.zig",
}
